{
  "name": "@rpollard00/pi-materia",
  "version": "0.1.2",
  "description": "A Pi extension for configurable, materia-themed agent pipelines.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "agent",
    "pipeline",
    "workflow"
  ],
  "files": [
    "src",
    "config",
    "docs",
    "README.md",
    "PI_MATERIA_PLAN.md",
    "LICENSE"
  ],
  "scripts": {
    "dev:webui": "vite --config src/webui/client/vite.config.ts",
    "dev:webui:server": "tsx watch src/webui/server/index.ts",
    "build:webui": "vite build --config src/webui/client/vite.config.ts && tsc -p src/webui/server/tsconfig.json --noEmit false",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:webui": "vitest run --config src/webui/client/vitest.config.ts",
    "typecheck": "tsc --noEmit && tsc -p src/webui/client/tsconfig.json --noEmit && tsc -p src/webui/server/tsconfig.json --noEmit",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run typecheck && npm run pack:dry-run"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "latest",
    "@mariozechner/pi-tui": "latest",
    "@tailwindcss/postcss": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "jsdom": "latest",
    "postcss": "latest",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
