{
  "name": "@rpollard00/pi-materia",
  "version": "0.1.1",
  "description": "A Pi extension for configurable, materia-themed agent pipelines.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "agent",
    "pipeline",
    "workflow"
  ],
  "files": [
    "src",
    "config",
    "README.md",
    "PI_MATERIA_PLAN.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run typecheck && npm run pack:dry-run"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "latest",
    "@types/node": "latest",
    "typescript": "latest"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
