{
  "artifactDir": ".pi/pi-materia",
  "activeLoadout": "Graph Semantics Example",
  "loadouts": {
    "Graph Semantics Example": {
      "entry": "Socket-1",
      "nodes": {
        "Socket-1": {
          "type": "utility",
          "utility": "project.ensureIgnored",
          "parse": "json",
          "params": { "patterns": [".pi/pi-materia/"] },
          "assign": { "artifactIgnore": "$" },
          "edges": [{ "when": "always", "to": "Socket-2" }]
        },
        "Socket-2": {
          "type": "utility",
          "utility": "vcs.detect",
          "parse": "json",
          "assign": { "vcs": "$" },
          "edges": [{ "when": "always", "to": "Socket-3" }]
        },
        "Socket-3": {
          "type": "agent",
          "materia": "planner",
          "parse": "json",
          "assign": { "workItems": "$.workItems", "guidance": "$.guidance" },
          "edges": [{ "when": "always", "to": "Socket-4" }]
        },
        "Socket-4": {
          "type": "agent",
          "materia": "Build",
          "parse": "text",
          "edges": [{ "when": "always", "to": "Socket-5" }]
        },
        "Socket-5": {
          "type": "agent",
          "materia": "Auto-Eval",
          "parse": "json",
          "assign": { "lastCheck": "$", "lastFeedback": "$.feedback" },
          "edges": [
            { "when": "satisfied", "to": "Socket-6" },
            { "when": "not_satisfied", "to": "Socket-4", "maxTraversals": 3 }
          ]
        },
        "Socket-6": {
          "type": "agent",
          "materia": "Maintain",
          "parse": "json",
          "assign": { "lastMaintain": "$" },
          "advance": { "cursor": "workItemIndex", "items": "state.workItems", "done": "end", "when": "satisfied" },
          "edges": [
            { "when": "not_satisfied", "to": "Socket-6", "maxTraversals": 3 },
            { "when": "always", "to": "Socket-4" }
          ]
        }
      },
      "loops": {
        "workItemIteration": {
          "label": "Build → Eval → Maintain until all work items complete",
          "nodes": ["Socket-4", "Socket-5", "Socket-6"],
          "consumes": { "from": "Socket-3", "output": "workItems" },
          "exit": { "from": "Socket-6", "when": "satisfied", "to": "end" }
        }
      }
    }
  },
  "materia": {
    "ensureArtifactsIgnored": {
      "type": "utility",
      "label": "Ensure artifacts ignored",
      "description": "Ensures .pi/pi-materia/ is ignored by the project.",
      "group": "Utility",
      "utility": "project.ensureIgnored",
      "parse": "json",
      "params": { "patterns": [".pi/pi-materia/"] },
      "assign": { "artifactIgnore": "$" }
    },
    "detectVcs": {
      "type": "utility",
      "label": "Detect VCS",
      "description": "Detects jj/git availability and repository root.",
      "group": "Utility",
      "utility": "vcs.detect",
      "parse": "json",
      "assign": { "vcs": "$" }
    },
    "planner": {
      "tools": "readOnly",
      "prompt": "Return only the generic handoff JSON envelope: { \"summary\": string, \"workItems\": [{ \"id\": string, \"title\": string, \"description\": string, \"acceptance\": string[], \"context\": { \"architecture\": string, \"constraints\": string[], \"dependencies\": string[], \"risks\": string[] } }], \"guidance\": {}, \"decisions\": [], \"risks\": [], \"satisfied\": true, \"feedback\": \"\", \"missing\": [] }. Use workItems, not tasks.",
      "generates": {
        "output": "workItems",
        "listType": "array",
        "itemType": "workItem",
        "as": "workItem",
        "cursor": "workItemIndex",
        "done": "end"
      }
    },
    "Build": {
      "tools": "coding",
      "prompt": "Implement the current workItem supplied by the socket adapter, using global guidance from state.guidance. Return a concise text implementation summary."
    },
    "Auto-Eval": {
      "tools": "readOnly",
      "prompt": "Evaluate the current workItem and return the generic handoff envelope with satisfied, feedback, and missing populated as reserved evaluator fields."
    },
    "Maintain": {
      "tools": "coding",
      "prompt": "Checkpoint accepted work and return JSON with satisfied plus maintenance details."
    }
  }
}
